# Copy to .env.local and fill in to enable realtime cross-device sync.
# Without these, the app falls back to single-device localStorage — still
# fully functional, just not shared across phones/browsers.
#
# Find both values in Supabase: Project Settings → API.
# Use the "anon public" key — never the "service_role" key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
